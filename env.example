# Supabase Configuration
# =====================
# Required for Supabase client initialization
# Get these values from your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"


# Authentication
# =============
# Optional: Set to 'true' to enable debug logging
NEXT_PUBLIC_DEBUG=true

# Session Configuration
# ===================
# Keep users logged in until manual logout
# Set to 'true' ONLY if you want automatic session timeout behavior
NEXT_PUBLIC_ENABLE_SESSION_TIMEOUT=false

# Optional: If timeouts are enabled, configure total timeout and warning (in minutes)
# NEXT_PUBLIC_SESSION_TIMEOUT_MS=30
# NEXT_PUBLIC_SESSION_WARNING_TIME_MS=5

# Session refresh interval in milliseconds (default: 5 minutes)
NEXT_PUBLIC_SESSION_REFRESH_INTERVAL=300000

# Development Settings
# ==================
# Set to 'true' to enable development mode features
NODE_ENV=development

# API Configuration
# ================
# Base URL for API requests (if different from the app URL)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Logging
# ======
# Log level: 'error', 'warn', 'info', 'debug', 'trace'
LOG_LEVEL=info

# Feature Flags
# ============
# Enable/disable specific features
NEXT_PUBLIC_FEATURE_AUTH=true
NEXT_PUBLIC_FEATURE_ANALYTICS=false

# Security
# =======
# Set a secure secret for session encryption
# Generate with: openssl rand -base64 32
# SECRET_COOKIE_PASSWORD=your-secure-cookie-password

# Rate Limiting
# =============
# Maximum number of login attempts before lockout
NEXT_PUBLIC_MAX_LOGIN_ATTEMPTS=5
# Lockout duration in minutes
NEXT_PUBLIC_LOCKOUT_DURATION=15

# CORS Configuration
# =================
# Comma-separated list of allowed origins
NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Email Configuration
# ==================
# SMTP settings for sending emails (if needed)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=noreply@example.com

# File Uploads
# ===========
# Maximum file size in bytes (default: 5MB)
NEXT_PUBLIC_MAX_UPLOAD_SIZE=5242880
# Allowed file types (comma-separated)
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# Note: Never commit actual values to version control.
# This file should only contain example values.
